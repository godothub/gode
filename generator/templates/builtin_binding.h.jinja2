#ifndef GODE_{{ class_name|upper }}_BINDING_GEN_H
#define GODE_{{ class_name|upper }}_BINDING_GEN_H

#include <godot_cpp/variant/builtin_types.hpp>
#include <godot_cpp/classes/object.hpp>
#include <napi.h>

namespace gode {

// Auto-generated bindings for {{ class_name }}
class {{ class_name }}Binding : public Napi::ObjectWrap<{{ class_name }}Binding> {
	friend class JavascriptInstance;

public:
	godot::{{ class_name }} instance;
    uint64_t owner_object_id = 0;
    godot::StringName owner_property;
    static Napi::FunctionReference constructor;
    static Napi::Object init(Napi::Env env, Napi::Object exports);
    {{ class_name }}Binding(const Napi::CallbackInfo& info);
    void bind_owner_property(godot::Object *owner, const godot::StringName &property);
    void sync_owner_property();
    
    // Methods
    {% for method in methods %}
    {% if method.is_static %}
    static Napi::Value {{ method.name_cpp }}(const Napi::CallbackInfo& info);
    {% else %}
    Napi::Value {{ method.name_cpp }}(const Napi::CallbackInfo& info);
    {% endif %}
    {% endfor %}

    // ToString
    Napi::Value _to_string(const Napi::CallbackInfo& info);
    {% if is_iterable_array %}
    Napi::Value _iterator(const Napi::CallbackInfo& info);
    {% endif %}

    // Members
    {% for member in members %}
    Napi::Value {{ member.getter }}(const Napi::CallbackInfo& info);
    void {{ member.setter }}(const Napi::CallbackInfo& info, const Napi::Value& value);
    {% endfor %}

    // Operators
    {% for op_group in operators %}
    {% if not op_group.name.startswith('operator_unary') and op_group.name != 'not' %}
    Napi::Value operator_{{ op_group.name }}(const Napi::CallbackInfo& info);
    {% endif %}
    {% endfor %}
};

} // namespace gode

#endif // GODE_{{ class_name|upper }}_BINDING_GEN_H
