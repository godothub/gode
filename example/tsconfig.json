{
  "compilerOptions": {
	"target": "ES2020",
	"module": "ESNext",
	"moduleResolution": "bundler",
	"strict": false,
	"noCheck": false,
	"outDir": "dist",
	"rootDir": ".",
	"esModuleInterop": true,
	"skipLibCheck": true,
	"jsx": "react",
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
